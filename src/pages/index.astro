  const heroSlider = document.getElementById('hero-slider')!
  const slides = heroSlider.querySelectorAll('.hero-slide') as NodeListOf<HTMLImageElement>
  let currentSlide = slides[0]
  let nextSlide = slides[1]
  nextSlide.style.transition = 'none'
  nextSlide.style.transform = 'translateX(100%)'

  setInterval(() => {
    heroIndex = (heroIndex + 1) % heroSlides.length
    // Prepare next slide off-screen right, no transition
    nextSlide.style.transition = 'none'
    nextSlide.style.transform = 'translateX(100%)'
    nextSlide.src = heroSlides[heroIndex]

    // Force reflow
    void nextSlide.offsetWidth

    // Animate both
    nextSlide.style.transition = 'transform 700ms ease-in-out'
    currentSlide.style.transition = 'transform 700ms ease-in-out'
    currentSlide.style.transform = 'translateX(-100%)'
    nextSlide.style.transform = 'translateX(0)'

    const temp = currentSlide
    currentSlide = nextSlide
    nextSlide = temp
  }, 4000)

<script>
  // Setup list viewer for both A and B
  function setupListViewer(listId: string, itemClass: string, previewId: string, dotClass: string) {
    const dots = document.querySelectorAll(`.${dotClass}`)
    const listItems = document.querySelectorAll(`.${itemClass}`)
    const previewImage = document.getElementById(previewId) as HTMLImageElement
    const workList = document.getElementById(listId)!

    const totalItems = listItems.length
    const setSize = totalItems / 3
    const firstOfMiddle = listItems[setSize] as HTMLElement
    workList.scrollTop = firstOfMiddle.offsetTop - workList.offsetTop

    let currentSrc = ''
    let mouseX = 0, mouseY = 0
    let scrolling = false
    let scrollTimer: number
    let dragging = false
    let dragStartY = 0
    let dragScrollTop = 0

    function updatePreview() {
      const el = document.elementFromPoint(mouseX, mouseY)?.closest(`.${itemClass}`) as HTMLElement | null
      if (!el) return
      const src = el.dataset.src!
      if (src === currentSrc) return
      currentSrc = src
      const title = el.dataset.title!
      previewImage.style.opacity = '0'
      setTimeout(() => {
        previewImage.src = src
        previewImage.alt = title
        previewImage.style.opacity = '1'
      }, 150)

      listItems.forEach(li => {
        li.classList.remove('border-[#5a7a5a]')
        li.classList.add('border-transparent')
      })
      el.classList.remove('border-transparent')
      el.classList.add('border-[#5a7a5a]')

      const idx = parseInt(el.dataset.index!)
      dots.forEach((d, i) => {
        if (i === idx) {
          d.classList.remove('bg-zinc-300')
          d.classList.add('bg-white')
        } else {
          d.classList.remove('bg-white')
          d.classList.add('bg-zinc-300')
        }
      })
    }

    workList.addEventListener('mousemove', (e) => {
      mouseX = e.clientX
      mouseY = e.clientY
      if (dragging) {
        const delta = dragStartY - e.clientY
        workList.scrollTop = dragScrollTop + delta
        return
      }
      if (!scrolling) updatePreview()
    })

    workList.addEventListener('mousedown', (e) => {
      dragging = true
      dragStartY = e.clientY
      dragScrollTop = workList.scrollTop
      workList.style.cursor = 'grabbing'
      e.preventDefault()
    })

    window.addEventListener('mouseup', () => {
      if (dragging) {
        dragging = false
        workList.style.cursor = 'grab'
        updatePreview()
      }
    })

    workList.style.cursor = 'grab'

    workList.addEventListener('scroll', () => {
      scrolling = true
      clearTimeout(scrollTimer)
      scrollTimer = window.setTimeout(() => {
        scrolling = false
        updatePreview()
      }, 50)
    })

    workList.addEventListener('scrollend', () => {
      const scrollTop = workList.scrollTop
      const scrollHeight = workList.scrollHeight
      const oneSetHeight = scrollHeight / 3
      if (scrollTop < oneSetHeight * 0.3) {
        workList.scrollTop = scrollTop + oneSetHeight
      } else if (scrollTop > oneSetHeight * 1.7) {
        workList.scrollTop = scrollTop - oneSetHeight
      }
    })
  }

  setupListViewer('work-list', 'work-list-item', 'preview-image-a', 'illust-a-dot')
  setupListViewer('work-list-b', 'work-list-item-b', 'preview-image-b', 'illust-b-dot')

  // Works cards + content
  const worksCards = document.getElementById('works-cards')!
  const worksTitle = document.getElementById('works-title')!
  const worksCardRow = document.getElementById('works-card-row')!
  const worksContent = document.getElementById('works-content')!
  const viewA = document.getElementById('view-illust-a')!
  const viewB = document.getElementById('view-illust-b')!
  const viewAnim = document.getElementById('view-animation')!
  const allViews = [viewA, viewB, viewAnim]
  const allCards = document.querySelectorAll('.works-landing-btn')
  let worksExpanded = false

  function expandWorks(tabId: string) {
    if (!worksExpanded) {
      worksExpanded = true
      // Shrink cards - keep justify-center, just reduce height
      worksCards.style.height = '5rem'
      worksCards.style.overflow = 'visible'
      worksTitle.classList.add('text-2xl', 'md:text-2xl', 'mb-2')
      worksTitle.classList.remove('text-6xl', 'md:text-8xl', 'mb-12')
      allCards.forEach(card => {
        const c = card as HTMLElement
        c.classList.remove('h-48', 'text-xl')
        c.classList.add('h-12', 'text-sm')
        const img = c.querySelector('img') as HTMLElement
        if (img) {
          img.classList.add('transition-opacity', 'duration-700')
          img.classList.add('opacity-0')
        }
        const overlay = c.querySelector('div.absolute') as HTMLElement
        if (overlay) {
          overlay.style.transition = 'background 700ms ease-in-out'
          overlay.style.background = '#5a7a5a'
        }
      })
      worksCardRow.classList.remove('gap-6')
      worksCardRow.classList.add('gap-3')
      // Show content
      setTimeout(() => {
        worksContent.style.maxHeight = 'calc(100vh - 10rem)'
        worksContent.style.marginTop = '1.5rem'
        worksContent.classList.remove('opacity-0')
        worksContent.classList.add('opacity-100')
      }, 100)
    }
    // Switch view
    const viewMap: Record<string, HTMLElement> = {
      'tab-illust-a': viewA,
      'tab-illust-b': viewB,
      'tab-animation': viewAnim,
    }
    allViews.forEach(v => v.classList.add('hidden'))
    viewMap[tabId]?.classList.remove('hidden')

    // Highlight active card
    allCards.forEach(card => {
      const c = card as HTMLElement
      if (c.dataset.tab === tabId) {
        c.classList.add('ring-2', 'ring-[#5a7a5a]')
      } else {
        c.classList.remove('ring-2', 'ring-[#5a7a5a]')
      }
    })
  }

  allCards.forEach(btn => {
    btn.addEventListener('click', () => {
      const tabId = (btn as HTMLElement).dataset.tab!
      expandWorks(tabId)
    })
  })

  // Animation video overlay
  const animItems = document.querySelectorAll('.anim-item')
  const animVideos = Array.from(animItems).map(item => (item as HTMLElement).dataset.video!)
  let currentAnimIndex = 0

  function openVideo(index: number) {
    currentAnimIndex = index
    const video = animVideos[currentAnimIndex]
    let overlay = document.getElementById('video-overlay')
    if (!overlay) {
      overlay = document.createElement('div')
      overlay.id = 'video-overlay'
      overlay.className = 'fixed inset-0 z-50 bg-black/90 flex items-center justify-center p-8'
      overlay.addEventListener('click', (e) => {
        const target = e.target as HTMLElement
        if (target.closest('#video-frame') || target.closest('#video-prev') || target.closest('#video-next')) return
        closeVideo()
      })
      document.body.appendChild(overlay)
      document.body.style.overflow = 'hidden'
    }
    overlay.innerHTML = `
      <button id="video-prev" class="absolute left-6 top-1/2 -translate-y-1/2 w-14 h-14 rounded-full bg-white/20 hover:bg-white/40 grid place-items-center z-10 transition-colors"><svg class="w-7 h-7 text-zinc-800" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg></button>
      <iframe id="video-frame" src="${video}?autoplay=1" class="w-full max-w-5xl aspect-video rounded-xl" allowfullscreen frameborder="0" allow="autoplay"></iframe>
      <button id="video-next" class="absolute right-6 top-1/2 -translate-y-1/2 w-14 h-14 rounded-full bg-white/20 hover:bg-white/40 grid place-items-center z-10 transition-colors"><svg class="w-7 h-7 text-zinc-800" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg></button>
    `
    overlay.querySelector('#video-prev')!.addEventListener('click', () => {
      openVideo((currentAnimIndex - 1 + animVideos.length) % animVideos.length)
    })
    overlay.querySelector('#video-next')!.addEventListener('click', () => {
      openVideo((currentAnimIndex + 1) % animVideos.length)
    })
  }

  function closeVideo() {
    const overlay = document.getElementById('video-overlay')
    if (overlay) {
      overlay.remove()
      document.body.style.overflow = ''
    }
  }

  animItems.forEach((item, i) => {
    item.addEventListener('click', () => openVideo(i))
  })

  document.addEventListener('keydown', (e) => {
    const overlay = document.getElementById('video-overlay')
    if (!overlay) return
    if (e.key === 'Escape') closeVideo()
    if (e.key === 'ArrowLeft') openVideo((currentAnimIndex - 1 + animVideos.length) % animVideos.length)
    if (e.key === 'ArrowRight') openVideo((currentAnimIndex + 1) % animVideos.length)
  })

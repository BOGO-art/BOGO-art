---

<Layout title="BOGO">
  <!-- Hero -->
  <section class="h-screen flex items-center px-6 scroll-snap-section relative overflow-hidden">
    <div class="flex items-center justify-between w-full gap-12 max-w-6xl mx-auto">
      <!-- Left text -->
      <div class="flex-1">
        <h1 class="text-7xl md:text-9xl font-extrabold tracking-tight mb-2 text-[#5a7a5a] leading-tight">
          BOGO
        </h1>
        <p class="text-xl text-zinc-500 mb-8" data-i18n="subtitle">Illustrator & Animator</p>
        <div class="flex gap-3">
          <a href="https://x.com/huk1325" target="_blank" class="w-10 h-10 rounded-full bg-white border border-zinc-200 flex items-center justify-center shadow-sm hover:shadow-md hover:border-zinc-300 transition-all relative">
            <svg class="w-4 h-4 text-zinc-600" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <span class="absolute -bottom-1 -right-1 w-4 h-4 rounded-full bg-[#5a7a5a] text-white text-[8px] font-bold flex items-center justify-center">KR</span>
          </a>
          <a href="https://x.com/yongsadragon" target="_blank" class="w-10 h-10 rounded-full bg-white border border-zinc-200 flex items-center justify-center shadow-sm hover:shadow-md hover:border-zinc-300 transition-all relative">
            <svg class="w-4 h-4 text-zinc-600" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <span class="absolute -bottom-1 -right-1 w-4 h-4 rounded-full bg-blue-400 text-white text-[8px] font-bold flex items-center justify-center">EN</span>
          </a>
          <a href="https://www.pixiv.net/users/90903246" target="_blank" class="w-10 h-10 rounded-full bg-white border border-zinc-200 flex items-center justify-center shadow-sm hover:shadow-md hover:border-blue-300 transition-all">
            <svg class="w-4 h-4 text-zinc-600" viewBox="0 0 24 24" fill="currentColor"><path d="M4.935 0A4.924 4.924 0 0 0 0 4.935v14.13A4.924 4.924 0 0 0 4.935 24h14.13A4.924 4.924 0 0 0 24 19.065V4.935A4.924 4.924 0 0 0 19.065 0zm7.81 4.547c2.181 0 4.058.676 5.399 1.847a6.118 6.118 0 0 1 2.116 4.66c.005 1.854-.88 3.476-2.257 4.563-1.375 1.085-3.211 1.697-5.258 1.697-2.02 0-3.788-.67-5.152-1.76A6.07 6.07 0 0 1 5.477 11.1c0-1.86.9-3.504 2.315-4.588 1.415-1.085 3.27-1.964 4.953-1.964zM12.58 6.2c-1.353 0-2.549.624-3.358 1.528A5.07 5.07 0 0 0 7.938 11.1a5.07 5.07 0 0 0 1.284 3.372c.809.904 2.005 1.528 3.358 1.528 1.353 0 2.549-.624 3.358-1.528A5.07 5.07 0 0 0 17.222 11.1a5.07 5.07 0 0 0-1.284-3.372C15.13 6.824 13.933 6.2 12.58 6.2zM3.2 17.286h3.12v2.572H3.2z"/></svg>
          </a>
          <a href="https://www.youtube.com/@Tofu-go4qc" target="_blank" class="w-10 h-10 rounded-full bg-white border border-zinc-200 flex items-center justify-center shadow-sm hover:shadow-md hover:border-red-300 transition-all">
            <svg class="w-4 h-4 text-zinc-600" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12z"/></svg>
          </a>
        </div>
      </div>
      <!-- Right hero image -->
      <div class="absolute right-0 top-[10%] w-[50vw] h-[70%] overflow-hidden" style="clip-path: ellipse(85% 100% at 100% 50%);">
        <div id="hero-slider" class="relative w-full h-full overflow-hidden">
          <img class="hero-slide absolute inset-0 w-full h-full object-cover blur-[3px] brightness-[0.85]" src="/BOGO-art/works/Aart2.jfif" />
          <img class="hero-slide absolute inset-0 w-full h-full object-cover blur-[3px] brightness-[0.85]" style="transform:translateX(100%)" src="/BOGO-art/works/Aart3.jfif" />
        </div>
      </div>
    </div>
  </section>


  <!-- Works -->
  <section id="works" class="max-w-6xl mx-auto px-6 pt-0 pb-0 h-screen scroll-snap-section overflow-hidden">
    <!-- Works Cards (act as both landing and tabs) -->
    <div id="works-cards" class="flex flex-col items-center justify-center transition-all duration-700 ease-in-out" style="height:80vh">
      <h2 id="works-title" class="text-6xl md:text-8xl font-extrabold mb-12 text-[#5a7a5a] transition-all duration-700">Works</h2>
      <div id="works-card-row" class="flex gap-6 transition-all duration-700">
        <button class="works-landing-btn group w-80 h-48 rounded-2xl text-xl font-medium text-white relative overflow-hidden transition-all duration-500 hover:scale-105 ring-1 border border-zinc-200 shadow-lg hover:shadow-xl" data-tab="tab-illust-a">
          <img src="/BOGO-art/works/Aart7.jfif" class="absolute inset-0 w-full h-full object-cover blur-[2px] brightness-[0.5] group-hover:brightness-[0.7] transition-all duration-300" />
          <div class="absolute inset-0 bg-black/30"></div>
          <span class="relative z-10 font-bold drop-shadow-lg" data-i18n="fairytale_btn">동화 일러스트</span>
        </button>
        <button class="works-landing-btn group w-80 h-48 rounded-2xl text-xl font-medium text-white relative overflow-hidden transition-all duration-500 hover:scale-105 ring-1 border border-zinc-200 shadow-lg hover:shadow-xl" data-tab="tab-illust-b">
          <img src="/BOGO-art/works/Bart4.jfif" class="absolute inset-0 w-full h-full object-cover blur-[2px] brightness-[0.5] group-hover:brightness-[0.7] transition-all duration-300" />
          <div class="absolute inset-0 bg-black/30"></div>
          <span class="relative z-10 font-bold drop-shadow-lg" data-i18n="character_btn">캐릭터 일러스트</span>
        </button>
        <button class="works-landing-btn group w-80 h-48 rounded-2xl text-xl font-bold text-white relative overflow-hidden transition-all duration-500 hover:scale-105 ring-1 border border-zinc-200 shadow-lg hover:shadow-xl" data-tab="tab-animation">
          <img src="https://img.youtube.com/vi/QA-COeEx6FA/hqdefault.jpg" class="absolute inset-0 w-full h-full object-cover blur-[2px] brightness-[0.5] group-hover:brightness-[0.7] transition-all duration-300" />
          <div class="absolute inset-0 bg-black/30"></div>
          <span class="relative z-10 font-bold drop-shadow-lg" data-i18n="animation_btn">애니메이션</span>
        </button>
      </div>
    </div>

    <!-- Works Content -->
    <div id="works-content" class="opacity-0 transition-all duration-700 overflow-hidden" style="max-height:0">

    <!-- Illust A View -->
    <div id="view-illust-a" class="flex h-full gap-4">
      <div class="flex flex-col items-center justify-center gap-2 pr-2" id="dots-a">
        {works.filter(w => w.category === 'illust-a').map((_, i) => (
          <div class:list={['illust-a-dot w-2 h-2 rounded-full transition-all', i === 0 ? 'bg-white' : 'bg-zinc-300']} />
        ))}
      </div>
      <div class="w-[10%] overflow-y-auto flex flex-col gap-2 work-list-container" id="work-list">
        {[0,1,2].map(() =>
          works.filter(w => w.category === 'illust-a').map((work, i) => (
            <button
              class:list={[
                'work-list-item rounded-lg overflow-hidden transition-all border-2 shrink-0',
                'border-transparent hover:border-[#6b8f6b]'
              ]}
              data-index={i}
              data-src={work.thumbnail}
              data-title={work.title}
            >
              <img src={work.thumbnail} alt={work.title} class="w-full aspect-square object-cover" />
            </button>
          ))
        )}
      </div>
      <div class="w-[90%] flex items-center justify-center">
        <img
          id="preview-image-a"
          src={works.filter(w => w.category === 'illust-a')[0].thumbnail}
          alt={works.filter(w => w.category === 'illust-a')[0].title}
          class="max-w-full max-h-full object-contain rounded-2xl shadow-lg border border-zinc-200 transition-opacity duration-300"
        />
      </div>
    </div>

    <!-- Illust B View -->
    <div id="view-illust-b" class="hidden flex h-[80vh] gap-4">
      <div class="flex flex-col items-center justify-center gap-2 pr-2" id="dots-b">
        {works.filter(w => w.category === 'illust-b').map((_, i) => (
          <div class:list={['illust-b-dot w-2 h-2 rounded-full transition-all', i === 0 ? 'bg-white' : 'bg-zinc-300']} />
        ))}
      </div>
      <div class="w-[10%] overflow-y-auto flex flex-col gap-2 work-list-container" id="work-list-b">
        {[0,1,2].map(() =>
          works.filter(w => w.category === 'illust-b').map((work, i) => (
            <button
              class:list={[
                'work-list-item-b rounded-lg overflow-hidden transition-all border-2 shrink-0',
                'border-transparent hover:border-[#6b8f6b]'
              ]}
              data-index={i}
              data-src={work.thumbnail}
              data-title={work.title}
            >
              <img src={work.thumbnail} alt={work.title} class="w-full aspect-square object-cover" />
            </button>
          ))
        )}
      </div>
      <div class="w-[90%] flex items-center justify-center">
        <img
          id="preview-image-b"
          src={works.filter(w => w.category === 'illust-b')[0].thumbnail}
          alt={works.filter(w => w.category === 'illust-b')[0].title}
          class="max-w-full max-h-full object-contain rounded-2xl shadow-lg border border-zinc-200 transition-opacity duration-300"
        />
      </div>
    </div>

    <!-- Animation View -->
    <div id="view-animation" class="hidden h-full overflow-y-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 content-start">
      {works.filter(w => w.category === 'animation').map(work => (
        <div class="anim-item aspect-video rounded-2xl overflow-hidden cursor-pointer relative group shadow-lg border border-zinc-200 hover:border-[#6b8f6b] transition-all" data-video={work.video}>
          <img src={work.thumbnail} alt={work.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
          <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/50 transition-colors">
            <div class="w-14 h-14 rounded-full bg-white/40 backdrop-blur-sm flex items-center justify-center group-hover:bg-white/60 transition-all">
              <svg class="w-6 h-6 text-zinc-800 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
      ))}
    </div>
    </div>
  </section>

  <!-- About + Contact -->
  <div class="scroll-snap-section min-h-screen">
  <section id="about" class="max-w-4xl mx-auto px-6 pt-20 pb-10">
    <h2 class="text-3xl font-extrabold mb-10 text-zinc-800" data-i18n="about_title">About</h2>
    <div class="flex gap-10 items-start">
      <!-- Profile card -->
      <div class="relative shrink-0">
        <img src="/BOGO-art/works/mainchara.jpg" alt="BOGO" class="relative w-52 h-52 rounded-2xl object-cover border border-zinc-200 shadow-md" />
      </div>
      <div class="flex-1">
        <p class="text-lg text-zinc-700 leading-relaxed mb-6" data-i18n="about_desc">
          안녕하세요, BOGO입니다.<br />
          일러스트와 애니메이션 전문 아티스트입니다.
        </p>
        <div class="grid grid-cols-1 gap-6">
          <div class="bg-white rounded-xl p-5 border border-zinc-200 shadow-sm">

---
import '../styles/global.css'

interface Props {
  title?: string
}

const { title = 'Portfolio' } = Astro.props
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="일러스트 & 애니메이션 포트폴리오" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-[#f0e6df] text-zinc-800 overflow-x-hidden">
    <nav class="fixed top-0 w-full z-50 bg-[#f0e6df]/80 backdrop-blur-xl border-b border-zinc-200/60">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/BOGO-art/" class="text-xl font-extrabold tracking-tight text-rose-500" id="nav-home">BOGO</a>
      </div>
    </nav>
    <main class="pt-16">
      <slot />
    </main>
    <div class="fixed right-6 top-1/2 -translate-y-1/2 z-50 flex items-center gap-4">
      <div id="lang-buttons" class="grid grid-cols-2 gap-2">
        <button class="lang-btn w-11 h-11 rounded-full bg-white text-rose-500 text-xs font-bold border border-zinc-200 shadow-sm transition-all hover:shadow-md" data-lang="ko">KR</button>
        <button class="lang-btn w-11 h-11 rounded-full bg-white/80 text-zinc-400 text-xs border border-zinc-200 hover:text-rose-500 hover:bg-white transition-all" data-lang="en">EN</button>
        <button class="lang-btn w-11 h-11 rounded-full bg-white/80 text-zinc-400 text-xs border border-zinc-200 hover:text-rose-500 hover:bg-white transition-all" data-lang="ja">JP</button>
        <button class="lang-btn w-11 h-11 rounded-full bg-white/80 text-zinc-400 text-xs border border-zinc-200 hover:text-rose-500 hover:bg-white transition-all" data-lang="zh">CN</button>
      </div>
      <div id="scroll-dots" class="flex flex-col gap-3">
        <button class="scroll-dot w-2.5 h-2.5 rounded-full bg-rose-400 transition-all" data-index="0"></button>
        <button class="scroll-dot w-2.5 h-2.5 rounded-full bg-zinc-300 transition-all" data-index="1"></button>
        <button class="scroll-dot w-2.5 h-2.5 rounded-full bg-zinc-300 transition-all" data-index="2"></button>
      </div>
    </div>
    <script is:inline>
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual'
      }
      window.scrollTo(0, 0)
      const sections = document.querySelectorAll('.scroll-snap-section')
      let currentSection = 0
      let isAnimating = false

      let accumulatedDelta = 0
      let deltaTimer = null

      window.addEventListener('wheel', (e) => {
        const scrollable = e.target.closest('#work-list, #work-list-b')
        if (scrollable) return

        e.preventDefault()
        if (isAnimating) return

        accumulatedDelta += e.deltaY
        clearTimeout(deltaTimer)
        deltaTimer = setTimeout(() => { accumulatedDelta = 0 }, 200)

        if (Math.abs(accumulatedDelta) > 50) {
          if (accumulatedDelta > 0) {
            goToSection(currentSection + 1)
          } else {
            goToSection(currentSection - 1)
          }
          accumulatedDelta = 0
        }
      }, { passive: false })

      const dots = document.querySelectorAll('.scroll-dot')

      function updateDots() {
        dots.forEach((dot, i) => {
          if (i === currentSection) {
            dot.classList.remove('bg-zinc-300')
            dot.classList.add('bg-rose-400')
          } else {
            dot.classList.remove('bg-rose-400')
            dot.classList.add('bg-zinc-300')
          }
        })
      }

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          goToSection(parseInt(dot.dataset.index))
        })
      })

      function goToSection(index) {
        if (index < 0 || index >= sections.length || isAnimating) return
        isAnimating = true
        currentSection = index
        const target = sections[currentSection]
        const navHeight = document.querySelector('nav').offsetHeight
        const top = target.offsetTop - navHeight
        window.scrollTo({ top: top, behavior: 'smooth' })
        updateDots()
        setTimeout(() => { isAnimating = false }, 700)
      }

      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.lang-btn').forEach(b => {
            b.classList.remove('bg-white', 'text-rose-500', 'font-bold', 'shadow-sm')
            b.classList.add('bg-white/80', 'text-zinc-400')
          })
          btn.classList.remove('bg-white/80', 'text-zinc-400')
          btn.classList.add('bg-white', 'text-rose-500', 'font-bold', 'shadow-sm')
        })
      })

      document.getElementById('nav-home').addEventListener('click', (e) => {
        e.preventDefault()
        goToSection(0)
      })
    </script>
  </body>
</html>
